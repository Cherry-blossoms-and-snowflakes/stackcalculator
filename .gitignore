# Minecraft Forge MDK 标准 .gitignore

# 编译生成的文件（这些不用上传）
/build/
/libs/
/out/

# IDE 配置文件（本地编辑器设置，别人不需要）
/.idea/
/.vscode/
*.iml
*.ipr
*.iws

# 运行环境生成的文件
/run/
/eclipse/
/.settings/
/.classpath
/.project

# Gradle 相关缓存（但 gradle/ 文件夹本身会保留）
/.gradle/
gradle-app.setting

# 日志文件
*.log
logs/

# 临时文件
*.tmp
*.bak
*.swp

# 系统文件
.DS_Store
Thumbs.db